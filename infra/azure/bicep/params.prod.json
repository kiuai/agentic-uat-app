{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "value": "eastus2" },
    "namePrefix": { "value": "kiutestprod" },
    "keyVaultName": { "value": "kiutest" },
    "apiImage": { "value": "<ACR_LOGIN_SERVER>/uat-app:latest" },
    "workerImage": { "value": "<ACR_LOGIN_SERVER>/uat-app:latest" },
    "pgAdmin": { "value": "pgadmin" },
    "pgPassword": { "value": "<PG_PASSWORD>" },
    "pgDatabase": { "value": "uat" },
    "pgSkuName": { "value": "Standard_D2s_v3" },
    "pgLocation": { "value": "centralus" },
    "redisCapacity": { "value": 1 },
    "vnetAddressPrefix": { "value": "10.0.0.0/16" },
    "acaSubnetPrefix": { "value": "10.0.1.0/24" },
    "peSubnetPrefix": { "value": "10.0.2.0/24" },
