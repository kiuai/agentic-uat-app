# ==============================================================================
# KAATS — Root Environment Template
# Copy to .env for local development.
# Production secrets come from Azure Key Vault via Container Apps secret refs.
# ==============================================================================

ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Azure AD / Entra ID ───────────────────────────────────────────────────────
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-aoai-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-aoai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=kaats-gpt4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure SQL (local dev uses sqlserver container) ────────────────────────────
AZURE_SQL_SERVER=localhost,1433
AZURE_SQL_DATABASE=kaats_dev
AZURE_SQL_USERNAME=sa
AZURE_SQL_PASSWORD=KaatsDevPass!2026
# Full connection string overrides individual vars when set:
# AZURE_SQL_CONNECTION_STRING=

# ── Azure Cosmos DB (local dev uses emulator) ─────────────────────────────────
AZURE_COSMOS_ENDPOINT=https://localhost:8081
AZURE_COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
AZURE_COSMOS_DATABASE=kaats

# ── Azure Service Bus (local dev uses emulator) ───────────────────────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SomeSecret=
AZURE_SERVICE_BUS_AI_JOBS_TOPIC=ai-jobs
AZURE_SERVICE_BUS_CRAWL_JOBS_TOPIC=crawl-jobs
AZURE_SERVICE_BUS_RESULT_EVENTS_TOPIC=result-events
AZURE_SERVICE_BUS_SUBSCRIPTION_NAME=kaats-worker

# ── Azure Blob Storage (local dev uses Azurite) ───────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UKvwFHKHkdGBJDNnJo5YApAAAtmDsGqOxSg==
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UKvwFHKHkdGBJDNnJo5YApAAAtmDsGqOxSg==;BlobEndpoint=http://localhost:10000/devstoreaccount1;

# ── Azure Key Vault (blank = read secrets from env directly) ──────────────────
AZURE_KEY_VAULT_URL=

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string-here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend Vite vars (also in frontend/.env.example) ───────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
